# Copy this file to .env.prod on the server. Do not commit .env.prod.

IMAGE_TAG=main

# Public HTTPS base URL served by your reverse proxy.
PUBLIC_BASE_URL=https://imageflow.example.com

# PostgreSQL. Use the same password value inside DATABASE_URL, URL-encoded if needed.
POSTGRES_PASSWORD=replace_with_strong_postgres_password
DATABASE_URL=postgres://agent:replace_with_url_encoded_postgres_password@postgres:5432/agent_imageflow?sslmode=disable

# Optional bind mounts. Leave empty or unset to use Docker named volumes.
AGENT_IMAGEFLOW_POSTGRES_DATA=
AGENT_IMAGEFLOW_REDIS_DATA=
AGENT_IMAGEFLOW_STORAGE_ROOT=

# Host-only ports for the external reverse proxy.
API_BIND_PORT=8081
WEB_BIND_PORT=8080

# Instance and Admin Console auth.
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
ADMIN_USERNAME=replace_with_admin_username
ADMIN_PASSWORD=replace_with_admin_password
ADMIN_SESSION_SECRET=replace_with_long_random_admin_session_value
ADMIN_SESSION_TTL_SECONDS=43200

# Defaults for generated tasks and scope.
DEFAULT_WORKSPACE_ID=ws_default
DEFAULT_PROJECT_ID=prj_xhs_anime
DEFAULT_CAMPAIGN_ID=cmp_7day_cover
DEFAULT_PROVIDER=mock

# Rate limits. Keep conservative defaults for self-hosted deployments.
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_INSTANCE_MAX_REQUESTS=120
RATE_LIMIT_PROJECT_MAX_REQUESTS=60

# Worker and provider concurrency.
WORKER_CONCURRENCY=6
WORKER_MAX_RETRIES=3
WORKER_RETRY_BASE_DELAY_SECONDS=15
PROVIDER_TIMEOUT_SECONDS=300
OPENAI_COMPATIBLE_MAX_CONCURRENCY=3
FAL_MAX_CONCURRENCY=3

# OpenAI-compatible provider. Leave empty to avoid real provider calls.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_CONNECT_TIMEOUT_SECONDS=30
OPENAI_COMPATIBLE_RESPONSE_HEADER_TIMEOUT_SECONDS=300
OPENAI_COMPATIBLE_TOTAL_TIMEOUT_SECONDS=300

# fal provider. Leave API key empty to avoid fal calls.
FAL_BASE_URL=https://queue.fal.run
FAL_REST_BASE_URL=https://rest.fal.ai
FAL_API_KEY=
FAL_MODEL=openai/gpt-image-2
FAL_POLL_INTERVAL_MS=1000

# Optional external best-of judge.
BEST_OF_HTTP_SCORER_URL=
BEST_OF_HTTP_SCORER_API_KEY=
BEST_OF_HTTP_SCORER_TIMEOUT_SECONDS=30

THUMBNAIL_MAX_WIDTH=720
THUMBNAIL_MAX_HEIGHT=720
